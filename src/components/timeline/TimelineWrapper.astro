---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { parse } from 'yaml';
import type { TimelineItem } from './Timeline';
import Timeline from './Timeline';

// 读取 YAML 配置文件
const timelineConfigPath = resolve(process.cwd(), 'config/timeline.yaml');
const timelineYaml = readFileSync(timelineConfigPath, 'utf-8');
const timelineData = parse(timelineYaml);

const items: TimelineItem[] = timelineData.timeline || [];
---

<Timeline items={items} client:load />
